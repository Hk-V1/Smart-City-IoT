{
  "version": 2,
  "name": "smart-city-dashboard",
  "builds": [
    {
      "src": "dashboard/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dashboard/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://your-render-app.onrender.com"
  }
}
